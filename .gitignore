# ========================================
# GitHub Models AI ChatBot - .gitignore
# ========================================

# === Node / JavaScript ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# === Backend specific ===
backend/__pycache__/
backend/.venv/
backend/*.pyc
backend/.env

# === Frontend sensitive files ===
# IMPORTANT: Keep config.js in gitignore to protect your token
frontend/js/config.js
frontend/js/config.local.js
frontend/.env
frontend/.env.local

# === IDE / Editor ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.editorconfig

# === Build & Dist ===
dist/
build/
*.log
*.tmp
.temp/

# === Secrets & Keys ===
*.pem
*.key
*.crt
.secrets/
.env
.env.*
!.env.example

# === OS generated ===
Thumbs.db
ehthumbs.db
Desktop.ini

# === Test coverage ===
.coverage
.nyc_output/
coverage/
htmlcov/

# === Cache ===
.cache/
*.cache
.eslintcache
.prettiercache

# === Backup files ===
*.bak
*.backup
*.old
*.orig

# === Docker ===
*.pid
docker-compose.override.yml

# === GitHub Actions local ===
.github/actions/cache/
.workflow-cache/

# === Misc ===
*.log
*.sql
*.sqlite
*.db
